import numpy as np
import os
import csv
import pandas as pd
from concurrent.futures import ProcessPoolExecutor, as_completed

# Simulation Parameters
CAVE_LENGTH = 300
NUM_MOLECULES = 10000  # Number of molecules per simulation
TOTAL_SIMULATIONS = 100  # Number of simulation loops
CAVE_WIDTH = 100
CAVE_HEIGHT = 60
Z_ORIGIN = 0

def get_velocity_x(x, y, z, phi, psi):
    if z == Z_ORIGIN or z == -Z_ORIGIN:
        return np.cos(phi) * np.cos(psi)
    elif z == CAVE_HEIGHT:
        return -np.cos(phi) * np.cos(psi)
    elif y == CAVE_WIDTH / 2:
        return -np.cos(phi) * np.cos(psi)
    elif y == -CAVE_WIDTH / 2:
        return np.cos(phi) * np.cos(psi)
    elif x == CAVE_LENGTH:
        return -np.sin(psi)
    elif x == -CAVE_LENGTH:
        return np.sin(psi)

def get_velocity_y(x, y, z, phi, psi):
    if z == Z_ORIGIN or z == -Z_ORIGIN:
        return np.sin(phi) * np.cos(psi)
    elif z == CAVE_HEIGHT:
        return -np.sin(phi) * np.cos(psi)
    elif y == CAVE_WIDTH / 2:
        return -np.sin(psi)
    elif y == -CAVE_WIDTH / 2:
        return np.sin(psi)
    elif x == CAVE_LENGTH:
        return np.cos(phi) * np.cos(psi)
    elif x == -CAVE_LENGTH:
        return -np.cos(phi) * np.cos(psi)

def get_velocity_z(x, y, z, phi, psi):
    if z == Z_ORIGIN or z == -Z_ORIGIN:
        return np.sin(psi)
    elif z == CAVE_HEIGHT:
        return -np.sin(psi)
    elif y == CAVE_WIDTH / 2:
        return np.sin(phi) * np.cos(psi)
    elif y == -CAVE_WIDTH / 2:
        return np.sin(phi) * np.cos(psi)
    elif x == CAVE_LENGTH:
        return np.sin(phi) * np.cos(psi)
    elif x == -CAVE_LENGTH:
        return np.sin(phi) * np.cos(psi)

def calculate_time_x(x, y, z, phi, psi):
    vx = get_velocity_x(x, y, z, phi, psi)
    if vx >= 0:
        return (CAVE_LENGTH - x) / vx
    elif vx < 0:
        return (CAVE_LENGTH + x) / abs(vx)

def calculate_time_y(x, y, z, phi, psi):
    vy = get_velocity_y(x, y, z, phi, psi)
    if vy >= 0:
        return ((CAVE_WIDTH / 2) - y) / vy
    elif vy < 0:
        return ((CAVE_WIDTH / 2) + y) / abs(vy)

def calculate_time_z(x, y, z, phi, psi):
    vz = get_velocity_z(x, y, z, phi, psi)
    if vz >= 0:
        return (CAVE_HEIGHT - z) / vz
    elif vz < 0:
        return z / abs(vz)

def get_minimum_time(x, y, z, phi, psi):
    return min(
        calculate_time_x(x, y, z, phi, psi), 
        calculate_time_y(x, y, z, phi, psi), 
        calculate_time_z(x, y, z, phi, psi)
    )

def simulate_flight_all_adsorptions(x, y, z):
    adsorption_xs = [x]
    while not (z == CAVE_HEIGHT and np.sqrt(x**2 + y**2) < CAVE_WIDTH / 2):
        phi = np.random.uniform(0, 2 * np.pi)
        psi = np.arcsin(np.sqrt(np.random.uniform(0, 1)))

        dt = get_minimum_time(x, y, z, phi, psi)
        vx = get_velocity_x(x, y, z, phi, psi)
        vy = get_velocity_y(x, y, z, phi, psi)
        vz = get_velocity_z(x, y, z, phi, psi)

        x, y, z = round(x + vx * dt, 2), round(y + vy * dt, 2), round(z + vz * dt, 2)

        if not (z == CAVE_HEIGHT and np.sqrt(x**2 + y**2) < CAVE_WIDTH / 2):
            adsorption_xs.append(x)
    return adsorption_xs

def run_simulation_process(cond):
    """Run flight simulation and return particle trace data."""
    particle_id, x, y, z = cond
    adsorption_xs = simulate_flight_all_adsorptions(x, y, z)
    return [[particle_id, count, x_val] for count, x_val in enumerate(adsorption_xs)]

if __name__ == "__main__":
    data_file = "adsorption_data_10_6_sim_include0.csv"

    # Do not add header if file already exists
    file_exists = os.path.isfile(data_file)
    mode = "a" if file_exists else "w"

    print(f"Starting simulation. Results will be saved to '{data_file}'.")

    with open(data_file, mode, newline="") as f:
        writer = csv.writer(f)
        if not file_exists:
            writer.writerow(
                ["particle_id", "adsorption_count", "adsorption_x"]
            )  # Header

        for loop_count in range(TOTAL_SIMULATIONS):
            print(f"--- Starting loop {loop_count + 1}/{TOTAL_SIMULATIONS} ---")

            # Generate initial conditions
            r = np.random.uniform(0, CAVE_WIDTH / 2, NUM_MOLECULES)
            angle = np.random.uniform(0, 2 * np.pi, NUM_MOLECULES)
            x = r * np.cos(angle)
            y = r * np.sin(angle)
            z = np.zeros(NUM_MOLECULES)

            # Global unique ID offset
            particle_id_offset = loop_count * NUM_MOLECULES

            # Execute simulation using ProcessPoolExecutor
            with ProcessPoolExecutor(max_workers=22) as executor:
                initial_conditions = list(
                    zip(range(particle_id_offset, particle_id_offset + NUM_MOLECULES), x, y, z)
                )
                futures = [
                    executor.submit(run_simulation_process, cond)
                    for cond in initial_conditions
                ]

                for i, future in enumerate(as_completed(futures)):
                    rows = future.result()
                    writer.writerows(rows)
                    # Show progress every 100 particles
                    if (i + 1) % 100 == 0:
                        print(f"  > Saved results for particle {i + 1}/{NUM_MOLECULES}.", end="\r")
            print(f"\n--- Loop {loop_count + 1} completed. ---")

    print("\nSimulation and data saving completed.")
