import numpy as np
import os
import csv
from concurrent.futures import ProcessPoolExecutor, as_completed

# Simulation Parameters
CAVE_LENGTH = 300
CAVE_WIDTH = 100
CAVE_HEIGHT = 60
PARTICLES_PER_SIM = 10000 
TOTAL_SIMULATIONS = 100 
Z_ORIGIN = 0

def get_velocity_x(x, y, z, phi, psi):
    """Calculates x-component of velocity."""
    if z == Z_ORIGIN or z == -Z_ORIGIN:
        return np.cos(phi) * np.cos(psi)
    elif z == CAVE_HEIGHT:
        return -np.cos(phi) * np.cos(psi)
    elif y == CAVE_WIDTH / 2:
        return -np.cos(phi) * np.cos(psi)
    elif y == -CAVE_WIDTH / 2:
        return np.cos(phi) * np.cos(psi)
    elif x == CAVE_LENGTH:
        return -np.sin(psi)
    elif x == -CAVE_LENGTH:
        return np.sin(psi)

def get_velocity_y(x, y, z, phi, psi):
    """Calculates y-component of velocity."""
    if z == Z_ORIGIN or z == -Z_ORIGIN:
        return np.sin(phi) * np.cos(psi)
    elif z == CAVE_HEIGHT:
        return -np.sin(phi) * np.cos(psi)
    elif y == CAVE_WIDTH / 2:
        return -np.sin(psi)
    elif y == -CAVE_WIDTH / 2:
        return np.sin(psi)
    elif x == CAVE_LENGTH:
        return np.cos(phi) * np.cos(psi)
    elif x == -CAVE_LENGTH:
        return -np.cos(phi) * np.cos(psi)

def get_velocity_z(x, y, z, phi, psi):
    """Calculates z-component of velocity."""
    if z == Z_ORIGIN or z == -Z_ORIGIN:
        return np.sin(psi)
    elif z == CAVE_HEIGHT:
        return -np.sin(psi)
    elif y == CAVE_WIDTH / 2:
        return np.sin(phi) * np.cos(psi)
    elif y == -CAVE_WIDTH / 2:
        return np.sin(phi) * np.cos(psi)
    elif x == CAVE_LENGTH:
        return np.sin(phi) * np.cos(psi)
    elif x == -CAVE_LENGTH:
        return np.sin(phi) * np.cos(psi)

def calculate_time_to_wall(x, y, z, phi, psi):
    """Calculates time until collision with walls."""
    vx = get_velocity_x(x, y, z, phi, psi)
    vy = get_velocity_y(x, y, z, phi, psi)
    vz = get_velocity_z(x, y, z, phi, psi)
    
    tx = (CAVE_LENGTH - x) / vx if vx >= 0 else (CAVE_LENGTH + x) / abs(vx)
    ty = ((CAVE_WIDTH / 2) - y) / vy if vy >= 0 else ((CAVE_WIDTH / 2) + y) / abs(vy)
    tz = (CAVE_HEIGHT - z) / vz if vz >= 0 else z / abs(vz)
    
    return min(tx, ty, tz)

def simulate_particle_flight(x, y, z):
    """Simulates particle trajectory and records adsorption points."""
    adsorption_history = [x]
    
    # Continue until absorbed on the top surface
    while not (z == CAVE_HEIGHT and np.sqrt(x**2 + y**2) < CAVE_WIDTH / 2):
        phi = np.random.uniform(0, 2 * np.pi)
        psi = np.arcsin(np.sqrt(np.random.uniform(0, 1)))

        dt = calculate_time_to_wall(x, y, z, phi, psi)
        
        x += get_velocity_x(x, y, z, phi, psi) * dt
        y += get_velocity_y(x, y, z, phi, psi) * dt
        z += get_velocity_z(x, y, z, phi, psi) * dt

        if not (z == CAVE_HEIGHT and np.sqrt(x**2 + y**2) < CAVE_WIDTH / 2):
            adsorption_history.append(round(x, 2))

    return adsorption_history

def run_simulation(args):
    """Worker function for parallel processing."""
    particle_id, x, y, z = args
    history = simulate_particle_flight(x, y, z)
    return [[particle_id, count, x_val] for count, x_val in enumerate(history)]

if __name__ == "__main__":
    output_csv = "adsorption_data.csv"
    file_exists = os.path.isfile(output_csv)
    
    print(f"Starting simulation. Results will be saved to '{output_csv}'.")

    with open(output_csv, "a", newline="") as f:
        writer = csv.writer(f)
        if not file_exists:
            writer.writerow(["particle_id", "adsorption_count", "adsorption_x"])

        for loop in range(TOTAL_SIMULATIONS):
            print(f"--- Starting iteration {loop + 1}/{TOTAL_SIMULATIONS} ---")

            # Generate initial positions
            r = np.random.uniform(0, CAVE_WIDTH / 2, PARTICLES_PER_SIM)
            angle = np.random.uniform(0, 2 * np.pi, PARTICLES_PER_SIM)
            init_x = r * np.cos(angle)
            init_y = r * np.sin(angle)
            init_z = np.zeros(PARTICLES_PER_SIM)

            with ProcessPoolExecutor(max_workers=22) as executor:
                tasks = [
                    (loop * PARTICLES_PER_SIM + i, init_x[i], init_y[i], init_z[i])
                    for i in range(PARTICLES_PER_SIM)
                ]
                
                futures = [executor.submit(run_simulation, task) for task in tasks]

                for i, future in enumerate(as_completed(futures)):
                    writer.writerows(future.result())
                    if (i + 1) % 100 == 0:
                        print(f"  > Progress: {i + 1}/{PARTICLES_PER_SIM} particles saved.", end="\r")
            
            print(f"\n--- Iteration {loop + 1} completed. ---")
